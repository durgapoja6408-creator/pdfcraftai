# PDFCraft AI — environment variables
#
# 2026-05-12 SEV-1 audit fix: this file was 60%+ stale (documented
# 18 vars, code references 46+). Disaster-recovery deploys from a
# fresh clone would have silently misconfigured a dozen surfaces.
# Comprehensive rewrite below — copy to .env.local for development,
# or set in Hostinger hPanel → Node.js app → Environment.
#
# Conventions:
#   - Empty value = feature off / gated
#   - Comments precede each var with a one-line purpose + format
#   - Optional vars marked [OPTIONAL]
#   - Vars Hostinger sets automatically marked [AUTO]
#   - Vars only needed at deploy time marked [DEPLOY]
# =============================================================

# ============== Site identity ==============

# Public canonical URL. Used for OAuth callbacks, OG/canonical
# meta, transactional email links. NO trailing slash.
NEXT_PUBLIC_SITE_URL=https://pdfcraftai.com

# Node port. [AUTO] Hostinger sets this; 3000 is local-dev default.
PORT=3000

# ============== Database ==============

# MySQL connection string.
# Local dev (docker-compose):
#   mysql://pdfcraft:pdfcraft_dev_password@127.0.0.1:3306/pdfcraft
# Hostinger prod (hPanel → Databases → MySQL):
#   mysql://<user>:<pwd>@<host>:3306/<db>?ssl={"rejectUnauthorized":true}
MYSQL_URL=mysql://pdfcraft:pdfcraft_dev_password@127.0.0.1:3306/pdfcraft

# MySQL connection pool size. Defaults to 10; clamped 1..50.
# Hostinger MariaDB per-account max-connections is ~25 — raise this
# above 15 only if you've consolidated the cron + worker draws on
# the same account.
MYSQL_POOL_SIZE=10

# ============== Auth (NextAuth v5) ==============

# NextAuth session secret. MUST be a random 32+ byte string.
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32

# Canonical auth URL. Usually matches NEXT_PUBLIC_SITE_URL.
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Cloud Console → APIs & Services → Credentials).
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Verification-gate kill switch. When "true", every /api/ai/* route
# rejects requests from users whose users.emailVerified IS NULL.
# Default OFF (false / unset). Flip during the email-verification
# rollout. See auth.ts events.signIn for the Google-OAuth side.
EMAIL_VERIFICATION_GATE=

# Cloudflare Turnstile (signup + reset-password CAPTCHA).
# Get from Cloudflare dashboard → Turnstile → New site.
# Leaving the SECRET unset fails open (skips Turnstile check)
# which is the dev-friendly default; live deploys MUST set it.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# Admin allowlist. Comma-separated emails. Gates /admin/* pages
# + ops routes that require admin context. Leave unset to fall
# back to the founder email hard-coded in lib/ai/margin-rollup.ts.
ADMIN_EMAILS=

# ============== AI providers ==============

# Set at least one provider to unlock AI features. The router falls
# back across providers per-op per the ladder in lib/ai/router.ts.
# Leaving all three unset disables every /api/ai/* route at boot.

ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Gemini accepts either name; GOOGLE_API_KEY for legacy callers.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash-exp
GOOGLE_API_KEY=

# ============== AI router knobs ==============

# Per-user-per-day cost cap in microdollars. Default $0.50/day.
# 500000 = $0.50.
USER_DAILY_COST_MICROS_CAP=500000

# Per-op signup-bonus cap (free credits used per tool per user).
# Default 5. Setting to 0 disables the per-op cap entirely.
BONUS_PER_OP_CAP=
BONUS_PER_OP_CAP_ENABLED=

# Auto-route bias: when "true", users with trailing thumbs-down
# streaks get their failing provider deprioritized in the ladder.
# Foundation shipped 2026-05-04; activation gated on 14 days of
# accumulated chip data.
QUALITY_SIGNAL_AUTO_ROUTE_ENABLED=

# Multiplier pricing for size-based ops. When "true", a 50-page
# doc costs more than a 5-page doc on the same op. Default OFF.
MULTIPLIER_PRICING_ENABLED=

# ============== Payments ==============

# Razorpay (India). Set all three to enable the Razorpay rail.
# Test-mode keys work fine in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Signup bonus + referral activation flags.
SIGNUP_GRANT_ENABLED=
REFERRALS_ENABLED=

# ============== Email (Hostinger SMTP) ==============

# Hostinger Mail → Email → SMTP credentials.
# SMTP_SECURE: "true" for port 465 (SSL), "false" for 587 (STARTTLS).
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=noreply@pdfcraftai.com
SMTP_FROM_NAME=pdfcraftai

# ============== Cron + Ops ==============

# Cron secret for /api/cron/* endpoints (expire-grants, reconcile-
# payments, ai-margin-rollup). MUST be sent via Authorization:
# Bearer <secret> header (NOT query string). Generate with:
# openssl rand -base64 32
CRON_SECRET=

# Slack webhook for ops alerts (margin-rollup failures, alert-floor
# breaches). Get from Slack → Incoming Webhooks. Leaving unset
# disables Slack alerting (the helper no-ops).
SLACK_OPS_WEBHOOK_URL=

# Legacy AI-spend Slack webhook. Kept for backwards-compat with
# the lib/ai/margin-rollup.ts URL override; prefer SLACK_OPS_*
# above for new alerters.
AI_SPEND_ALERT_SLACK_URL=

# Days to retain orphan files before the daily cleanup hard-deletes
# them. Default 7. Lower for tighter retention; higher for grace.
ORPHAN_CLEANUP_DAYS=7

# Panic kill-switch for the /api/tools/pdf-to-office free tool.
# Set to "true" to return 503 to every request (used during an
# active abuse incident — the route is public + heavyweight server-
# side conversion). Default unset = route normal.
PDF_TO_OFFICE_DISABLED=

# IP-salt for the geo waitlist hash (privacy-preserving signup
# tracking). Generate with: openssl rand -base64 16
GEO_WAITLIST_IP_SALT=

# ============== Public API ==============

# Master API key (server-side ops, never client-side). Used by
# the /api/v1/* surface. Generate: openssl rand -base64 32
PDFCRAFT_API_KEY=

# Webhook signing secret for API consumers. Generate as above.
PDFCRAFT_WEBHOOK_SECRET=

# ============== Analytics + Ads ==============

# Google AdSense publisher ID (ca-pub-XXXXXXXX format). Unset
# disables ad slots entirely. AdSlot component falls back to
# house-promo content when this is unset.
GOOGLE_ADSENSE_PUBLISHER_ID=

# ============== Feature flags (lib/flags.ts) ==============

# Each flag follows the pattern:
#   FEATURE_<name>_OVERRIDE   "on" | "off" | unset  (kill-switch)
#   FEATURE_<name>_PERCENT    0-100  (rollout percent)
#   FEATURE_<name>_USERS      "u1,u2,u3"  (allowlist)
#
# Known flags (see lib/flags.ts FEATURE_FLAGS const):
#   annual_plan, referral_program, pdf_compress, pdf_a_convert,
#   edit_pdf_text, homepage_hero_cta
#
# Examples (all leave the flag off by default):
# FEATURE_PDF_COMPRESS_OVERRIDE=on
# FEATURE_HOMEPAGE_HERO_CTA_PERCENT=25

# ============== Build metadata ==============

# [DEPLOY] Populated by deploy pipeline. Used in /api/health +
# /admin/margin to show which commit is running.
BUILD_COMMIT_SHA=
BUILD_RECENT_COMMITS=
BUILD_TIMESTAMP=
DEPLOY_TIMESTAMP=
COMMIT_SHA=
GIT_COMMIT=
NEXT_PUBLIC_COMMIT_SHA=
# Vercel-style fallback (not used in Hostinger deploys but
# referenced as a fallback in the same lookup chain).
VERCEL_GIT_COMMIT_SHA=
