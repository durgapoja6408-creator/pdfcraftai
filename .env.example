# PDFCraft AI — environment variables
# Copy this to .env.local for development, or set in Hostinger hPanel → Node.js app → Environment

# Public site URL
NEXT_PUBLIC_SITE_URL=https://pdfcraftai.com

# Node port — Hostinger sets this automatically; 3000 is the default for local dev
PORT=3000

# --- Phase 2: auth + database ---

# MySQL connection string.
# Local dev (via docker-compose.yml):
#   mysql://pdfcraft:pdfcraft_dev_password@127.0.0.1:3306/pdfcraft
# Hostinger prod (hPanel → Databases → MySQL):
#   mysql://<user>:<password>@<host>:3306/<database>?ssl={"rejectUnauthorized":true}
MYSQL_URL=mysql://pdfcraft:pdfcraft_dev_password@127.0.0.1:3306/pdfcraft

# NextAuth — secret must be a random 32+ byte string
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=replace-me-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth (Cloud Console → APIs & Services → Credentials → OAuth client ID)
# Authorized redirect URI: {NEXTAUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Phase 4: payments ---
# Set all three for Razorpay; leave unset to hide the Razorpay button.
# Test-mode keys work fine in dev.
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# Set all four for Paddle; leave unset to hide the Paddle (international)
# button. Paddle is our merchant-of-record for non-IN customers — it
# handles VAT/GST/sales-tax collection and remittance globally.
# PADDLE_ENV: "sandbox" (dev + verification) or "live" (prod).
# Generate API keys in the Paddle vendor dashboard:
#   Developer Tools → Authentication → API keys   (PADDLE_API_KEY, server-side)
#   Developer Tools → Authentication → Client-side tokens   (PADDLE_CLIENT_TOKEN, browser Paddle.js)
#   Developer Tools → Notifications → (destination) → signing secret   (PADDLE_WEBHOOK_SECRET)
PADDLE_API_KEY=
PADDLE_CLIENT_TOKEN=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENV=sandbox

# Cron secret for the nightly reconciliation job (prod only).
# Generate with: openssl rand -base64 32
# CRON_SECRET=

# --- Phase 5: AI ---
# Set at least one provider to unlock /app/chat. Leave both unset to
# hide the chat UI. Both configured at once is fine — each chat session
# locks to the provider it opened with on its first turn.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
